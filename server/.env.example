# Server Configuration
PORT=3001

# CORS Configuration
CORS_ORIGIN=*

# Data Update Intervals (milliseconds)
FLIGHTS_INTERVAL=10000
EARTHQUAKES_INTERVAL=60000
SATELLITES_INTERVAL=60000

# Cache Configuration
CACHE_MAX_SIZE=100
CACHE_CLEANUP_INTERVAL=60000

# WebSocket Configuration
WEBSOCKET_COMPRESSION_THRESHOLD=1024

# API Keys
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
# OPENWEATHER_API_KEY=your_api_key_here
# NEWS_API_KEY=
# MARITIME_API_KEY=
